<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настройки"
        android:textSize="24sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:paddingTop="16dp"
        android:paddingStart="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:paddingTop="0dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Профиль пользователя -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background_secondary"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Профиль"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Имя пользователя -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Логин:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_username"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="username"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Email:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="email@example.com"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Полное имя -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Имя:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_full_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Не указано"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Редактировать имя"
                        android:backgroundTint="@color/card_background"
                        android:textColor="@color/primary"
                        style="@style/Widget.Material3.Button.OutlinedButton"

                        app:iconGravity="textStart"
                        app:iconTint="@color/primary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Предпочтения (НОВАЯ КАРТОЧКА) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_preferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background_secondary"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Предпочтения"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Единицы расстояния -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Единицы расстояния:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_distance_unit_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="км"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_change_distance_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Изменить"
                            android:backgroundTint="@color/primary"
                            style="@style/Widget.Material3.Button" />
                    </LinearLayout>

                    <!-- Тема -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Тема:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_theme_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Системная"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_change_theme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Изменить"
                            android:backgroundTint="@color/primary"
                            style="@style/Widget.Material3.Button" />
                    </LinearLayout>

                    <!-- Язык -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Язык:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_language_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Русский"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_change_language"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Изменить"
                            android:backgroundTint="@color/primary"
                            style="@style/Widget.Material3.Button" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Синхронизация -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background_secondary"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Синхронизация"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Статус синхронизации -->
                    <LinearLayout
                        android:id="@+id/ll_sync_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:padding="12dp"
                        android:background="@color/card_background"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/progress_sync"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="12dp"
                            android:indeterminateTint="@color/primary"/>

                        <TextView
                            android:id="@+id/tv_sync_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Синхронизация..."
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Последняя синхронизация -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Последняя синхронизация:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_last_sync"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="никогда"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_sync_now"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Синхронизировать сейчас"
                        android:backgroundTint="@color/primary"

                        app:iconGravity="textStart"
                        app:iconTint="@android:color/white" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Безопасность -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_security"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background_secondary"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Безопасность"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btn_change_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Изменить пароль"
                        android:backgroundTint="@color/card_background"
                        android:textColor="@color/primary"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginBottom="12dp"

                        app:iconGravity="textStart"
                        app:iconTint="@color/primary" />

                    <Button
                        android:id="@+id/btn_delete_account"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Удалить аккаунт"
                        android:backgroundTint="@color/card_background"
                        android:textColor="@color/error"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginBottom="12dp"

                        app:iconGravity="textStart"
                        app:iconTint="@color/error" />

                    <Button
                        android:id="@+id/btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Выйти"
                        android:backgroundTint="@color/error"

                        app:iconGravity="textStart"
                        app:iconTint="@android:color/white" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- О приложении -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background_secondary"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="О приложении"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Версия:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_version"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Сервер:"
                            android:textColor="@color/text_hint"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_server_url"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="http://localhost:8000"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>